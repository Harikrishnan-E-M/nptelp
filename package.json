{
  "name": "nptel-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:all": "npm run build:frontend && npm run build:sanity && npm run copy-sanity",
    "build:frontend": "npm run build --prefix frontend",
    "build:sanity": "npm run build --prefix sanity",
    "copy-sanity": "node scripts/copy-sanity.js",
    "dev:frontend": "npm run dev --prefix frontend",
    "dev:sanity": "npm run dev --prefix sanity"
  }
}
